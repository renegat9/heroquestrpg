APP_NAME="HeroQuest MJ IA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de données (conteneur mariadb) ─────────────────────
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=heroquest
DB_USERNAME=heroquest
DB_PASSWORD=
DB_ROOT_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Temps réel (Reverb) — REVERB_HOST = IP LAN pour jouer en réseau ──
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=heroquest
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local

# Jobs IA (narration, menus, compactage) — worker `queue`
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# ── Qdrant (bible RAG, isolée par payload group_id) ─────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── LLM (agent MJ) — jamais dans l'image Docker ─────────────
# Fournisseur du texte du MJ (histoire + narration) : anthropic (défaut) | gemini.
# Choix GLOBAL ; « gemini » exige GEMINI_API_KEY (sinon repli Anthropic).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Modèle Claude du MJ quand LLM_PROVIDER=anthropic.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embeddings de la bible RAG (Voyage AI) ──────────────────
# Sans clé : repli lexical factice (dev). https://dash.voyageai.com
VOYAGE_API_KEY=

# ── Google Gemini (TTS des barks + LLM texte si LLM_PROVIDER=gemini) ─
# TTS : génère les fichiers audio (php artisan barks:generer). Sans clé, l'écran
# de table lit le texte via Web Speech (jouable). Si LLM_PROVIDER=gemini, cette
# même clé sert aussi à générer l'histoire/narration du MJ (modèle GEMINI_MODEL).
# Clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modèle texte du MJ quand LLM_PROVIDER=gemini (distinct du modèle TTS).
# flash-lite : ~18× plus rapide en jeu que 2.5-flash, qualité narrative OK.
GEMINI_MODEL=gemini-3.1-flash-lite
# Modèle image (illustrations : héros, monstres, objets, pièges, scènes, boss).
# Pré-génération hors-ligne (php artisan images:generer) + jobs en arrière-plan.
# Sans clé/asset : repli sur les icônes (jouable). Sert aussi via GEMINI_API_KEY.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── Docker : alignement des droits sur l'utilisateur hôte ───
UID=1000
GID=1000
